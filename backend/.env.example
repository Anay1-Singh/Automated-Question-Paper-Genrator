# ──────────────────────────────────────────────
# PaperMind AI — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# Application
APP_NAME=PaperMind AI
APP_ENV=development
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/papermind

# Authentication (JWT — future)
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=./uploads

# AI / NLP (future)
AI_MODEL_NAME=bert-base-uncased

# CORS
FRONTEND_URL=http://localhost:5173
